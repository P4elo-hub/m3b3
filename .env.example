# OpenAI-совместимый API
OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# Модель ассистента (primary / OpenAI)
SUPPORT_PRIMARY_MODEL=gpt-4o-mini

# --- Fallback: переключатель backend ---
# ollama  — локальная модель через Ollama (офлайн после pull)
# deepseek — DeepSeek API (pay-as-you-go, стартовые credits у новых аккаунтов)
FALLBACK_BACKEND=ollama

# Ollama (FALLBACK_BACKEND=ollama)
FALLBACK_API_KEY=ollama
FALLBACK_BASE_URL=http://localhost:11434/v1
# Локальные: qwen2.5:7b, llama3.2:3b (gemma3:1b — без tools)
# Облако Ollama (signin + Pro): deepseek-v4-flash:cloud
FALLBACK_MODEL=qwen2.5:7b

# DeepSeek API (FALLBACK_BACKEND=deepseek)
# Ключ: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# deepseek-chat → V4 Flash; deepseek-reasoner → reasoning
DEEPSEEK_MODEL=deepseek-chat

# Имя ассистента в промптах
SUPPORT_SERVICE_NAME=DocIntel

# Таймаут одного запроса к LLM (секунды); для sectioned лучше 180–300
SUPPORT_TIMEOUT_SECONDS=180

# Максимум раундов tool_call за один запрос
SUPPORT_MAX_TOOL_ROUNDS=8

# Папка с Markdown-документацией (поиск по заголовкам)
# SUPPORT_DOCS_DIR=app/data/docs

# Методология и шаблон фичи (write_feature_doc)
# SUPPORT_METHODOLOGY_DIR=feature-methodology-project
# SUPPORT_SHABLON_PATH=feature-methodology-project/shablon.md

# Дополнительный плоский индекс (опционально)
# SUPPORT_KB_PATH=app/data/knowledge_base.txt
